{
  "_comment": "AetherShell Panel Layout — edit to customise your panel.",
  "panel": {
    "height": 36,
    "spacing": 0,
    "margin": {
      "top": 0,
      "left": 0,
      "right": 0
    }
  },
  "layout": {
    "left": [
      {
        "type": "pill",
        "id": "keyboard-pill",
        "spacing": 0,
        "plugins": [
          "aether-keyboard"
        ]
      }
    ],
    "center": [
      {
        "type": "pill",
        "id": "status-pill",
        "spacing": 0,
        "plugins": [
          "aether-wifi",
          "aether-bt",
          "aether-mic",
          "aether-volume"
        ]
      },
      {
        "type": "pill",
        "id": "center-pill",
        "spacing": 0,
        "plugins": [
          "aether-appmenu",
          "aether-clipboard",
          "aether-workspaces",
          "aether-clock",
          "net-speed",
          "launcher"
        ]
      },
      {
        "type": "pill",
        "id": "sys-pill",
        "spacing": 0,
        "plugins": [
          "aether-battery",
          "aether-search",
          "aether-notifs",
          "aether-cc"
        ]
      }
    ],
    "right": [
      {
        "type": "pill",
        "id": "sni-pill",
        "spacing": 0,
        "plugins": [
          "aether-sni-tray"
        ]
      }
    ]
  }
}